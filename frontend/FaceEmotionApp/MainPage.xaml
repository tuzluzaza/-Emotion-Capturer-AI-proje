<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FaceEmotionApp.ViewModels"
             x:Class="FaceEmotionApp.MainPage"
             BackgroundColor="#0F1923"
             Title="Giriş">

    <ContentPage.BindingContext>
        <viewmodels:MainViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="30,50,30,30">

            <!-- LOGO / BAŞLIK -->
            <Label Text="🏢" FontSize="56" HorizontalOptions="Center" />
            <Label Text="Bina Erişim Sistemi"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="White" HorizontalOptions="Center" Margin="0,8,0,4"/>
            <Label Text="Kimliğinizi doğrulamak için yüzünüzü okutun"
                   FontSize="13" TextColor="#8899AA"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"
                   Margin="0,0,0,30"/>

            <!-- FOTOĞRAF ÇERÇEVE -->
            <Frame BorderColor="#1E3A5F" CornerRadius="20"
                   HeightRequest="280" WidthRequest="280"
                   HorizontalOptions="Center"
                   BackgroundColor="#1A2533"
                   HasShadow="True" Padding="0"
                   IsClippedToBounds="True">
                <Grid>
                    <Label Text="📷" FontSize="48"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           IsVisible="{Binding HasImage, Converter={StaticResource InverseBoolConverter}}" />
                    <Image Source="{Binding ImagePath}"
                           Aspect="AspectFill"
                           IsVisible="{Binding HasImage}" />
                </Grid>
            </Frame>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#00A8FF"
                               HorizontalOptions="Center"
                               Margin="0,16,0,0"/>

            <Label Text="{Binding StatusMessage}"
                   TextColor="#00A8FF" FontSize="13"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,8,0,0"
                   IsVisible="{Binding IsBusy}"/>

            <!-- AŞAMA 1: YÜZ TARAMA -->
            <VerticalStackLayout Spacing="12" Margin="0,24,0,0"
                                 IsVisible="{Binding IsFaceCaptureState}">
                <Button Text="📸  Fotoğraf Çek ve Giriş Yap"
                        Command="{Binding CaptureAndLoginCommand}"
                        BackgroundColor="#00A8FF" TextColor="White"
                        CornerRadius="16" HeightRequest="56"
                        FontAttributes="Bold" FontSize="16"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            </VerticalStackLayout>

            <!-- AŞAMA 2: YENİ KAYIT (bilinmeyen yüz) -->
            <VerticalStackLayout Spacing="14" Margin="0,24,0,0"
                                 IsVisible="{Binding IsRegisterNewPersonState}">
                <Frame BackgroundColor="#1A2A1A" BorderColor="#27AE60" CornerRadius="12" Padding="16">
                    <Label Text="⚠️  Kişi bulunamadı. Sisteme kayıt olun."
                           TextColor="#2ECC71" HorizontalTextAlignment="Center" FontSize="14"/>
                </Frame>

                <Label Text="Adınız Soyadınız" TextColor="#8899AA" FontSize="12" Margin="4,0,0,0"/>
                <Entry Placeholder="Örn: Ahmet Yılmaz"
                       Text="{Binding PersonNameToRegister}"
                       BackgroundColor="#1A2533" TextColor="White"
                       PlaceholderColor="#445566"
                       HeightRequest="52" />

                <Label Text="Rolünüzü Seçin" TextColor="#8899AA" FontSize="12" Margin="4,4,0,0"/>
                <Picker Title="Rol seçin..."
                        ItemsSource="{Binding AvailableRoles}"
                        SelectedItem="{Binding SelectedRole}"
                        BackgroundColor="#1A2533" TextColor="White"
                        TitleColor="#445566"
                        HeightRequest="52"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                    <Button Grid.Column="0" Text="İptal"
                            Command="{Binding ResetToLoginCommand}"
                            BackgroundColor="#2C3E50" TextColor="White"
                            CornerRadius="12" HeightRequest="50"/>
                    <Button Grid.Column="1" Text="Kaydet ve Giriş"
                            Command="{Binding RegisterAndLoginCommand}"
                            BackgroundColor="#27AE60" TextColor="White"
                            CornerRadius="12" HeightRequest="50"
                            FontAttributes="Bold"/>
                </Grid>
            </VerticalStackLayout>

            <!-- AŞAMA 3: ROL ATAMA (tanınan yüz ama rolü yok) -->
            <VerticalStackLayout Spacing="14" Margin="0,24,0,0"
                                 IsVisible="{Binding IsAssignRoleState}">
                <Frame BackgroundColor="#1A2233" BorderColor="#00A8FF" CornerRadius="12" Padding="16">
                    <Label Text="{Binding RecognizedPersonName, StringFormat='👤  Merhaba, {0}! Lütfen rolünüzü seçin.'}"
                           TextColor="#00A8FF" HorizontalTextAlignment="Center" FontSize="14"/>
                </Frame>

                <Label Text="Rolünüzü Seçin" TextColor="#8899AA" FontSize="12" Margin="4,0,0,0"/>
                <Picker Title="Rol seçin..."
                        ItemsSource="{Binding AvailableRoles}"
                        SelectedItem="{Binding SelectedRole}"
                        BackgroundColor="#1A2533" TextColor="White"
                        TitleColor="#445566"
                        HeightRequest="52"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                    <Button Grid.Column="0" Text="İptal"
                            Command="{Binding ResetToLoginCommand}"
                            BackgroundColor="#2C3E50" TextColor="White"
                            CornerRadius="12" HeightRequest="50"/>
                    <Button Grid.Column="1" Text="Rolü Onayla"
                            Command="{Binding AssignRoleAndLoginCommand}"
                            BackgroundColor="#00A8FF" TextColor="White"
                            CornerRadius="12" HeightRequest="50"
                            FontAttributes="Bold"/>
                </Grid>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
